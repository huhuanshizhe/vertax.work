# Local env (do not commit)
DATABASE_URL=
NEXT_PUBLIC_SITE_URL=https://www.vertax.work
AUTH_SECRET=

# Social OAuth relay → Electron deep-link callbacks
LINKEDIN_CALLBACK_URL=vertax://linkedin/authorization
TIKTOK_CALLBACK_URL=vertax://tiktok/authorization
TWITTER_CALLBACK_URL=vertax://twitter/authorization
FACEBOOK_CALLBACK_URL=vertax://facebook/authorization
YOUTUBE_CALLBACK_URL=vertax://youtube/authorization
DESKTOP_LOGIN_CALLBACK_URL=vertax://account/login

# Ed25519 license signing (generate with: node -e "..." or licence/server/scripts/gen-keys.ts)
LICENCE_SALT=
LICENCE_PRIVATE_KEY=
LICENCE_PUBLIC_KEY=

# Alipay — Sandbox（开放平台沙箱应用）
# PRIVATE_KEY = 应用私钥（选「非JAVA语言」复制；误贴公钥会报 DECODER unsupported）
# ALIPAY_PUBLIC_KEY = 支付宝公钥（页面下方「支付宝公钥」，不是应用公钥）
ALIPAY_SANDBOX_APP_ID=
ALIPAY_SANDBOX_PRIVATE_KEY=
ALIPAY_SANDBOX_ALIPAY_PUBLIC_KEY=
ALIPAY_SANDBOX_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# Alipay — Live（后续生产）
ALIPAY_LIVE_APP_ID=
ALIPAY_LIVE_PRIVATE_KEY=
ALIPAY_LIVE_ALIPAY_PUBLIC_KEY=
ALIPAY_LIVE_GATEWAY=https://openapi.alipay.com/gateway.do

# 可选；默认 {NEXT_PUBLIC_SITE_URL}/pay/{orderNumber}?returning=1
ALIPAY_RETURN_URL=
